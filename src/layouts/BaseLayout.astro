---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image = "/brand/social-card-light-1200x630.png",
} = Astro.props;
const pageTitle = title === "TaMTAS" ? title : `${title} | TaMTAS`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ResearchProject",
  name: "TaMTAS",
  alternateName:
    "Terminology-Aware Machine Translation for Accessible Science",
  url: Astro.site,
  description,
  member: [
    "Universitat Oberta de Catalunya",
    "Barcelona Supercomputing Center",
    "University of Surrey",
    "Dublin City University",
    "University of Tartu",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4f4f5" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/brand/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/brand/favicon-32.png" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="TaMTAS news" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/site";
    </script>
  </body>
</html>
