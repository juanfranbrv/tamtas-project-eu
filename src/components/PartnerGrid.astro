---
import { partners } from "../data/project";
---

<div class="partner-grid">
  {
    partners.map((partner) => (
      <a class="partner-entry" href={partner.href} data-reveal>
        <div class="partner-heading">
          <span>{partner.short}</span>
          <small>{partner.country}</small>
        </div>
        <h3>{partner.name}</h3>
        <p>{partner.description}</p>
        <strong>{partner.lead}</strong>
        <span class="partner-link" aria-hidden="true">Visit institution ↗</span>
      </a>
    ))
  }
</div>
