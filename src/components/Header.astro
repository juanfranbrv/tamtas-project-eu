---
import { navigation } from "../data/navigation";

const currentPath = Astro.url.pathname;
---

<header class="site-header" data-header>
  <div class="header-shell">
    <a class="brand" href="/" aria-label="TaMTAS home">
      <img src="/brand/tamtas-logo.svg" alt="TaMTAS" width="1430" height="360" />
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-controls="primary-navigation"
      aria-expanded="false"
      data-menu-toggle
    >
      <span class="menu-toggle-label">Menu</span>
      <span class="menu-toggle-lines" aria-hidden="true"></span>
    </button>

    <nav id="primary-navigation" class="primary-navigation" aria-label="Primary navigation" data-menu>
      {
        navigation.map((item) => (
          <a
            href={item.href}
            aria-current={currentPath.startsWith(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a class="header-resource" href="/resources">
      Open resources
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>
