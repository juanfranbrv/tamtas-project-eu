---
import BaseLayout from "../layouts/BaseLayout.astro";
import LanguageField from "../components/LanguageField.astro";
import PartnerGrid from "../components/PartnerGrid.astro";
import PrismHero from "../components/PrismHero.astro";
import ProjectStats from "../components/ProjectStats.astro";
import ResearchPipeline from "../components/ResearchPipeline.astro";
import { tools } from "../data/project";
---

<BaseLayout
  title="TaMTAS"
  description="TaMTAS is building terminology-aware machine translation and text augmentation for accurate, multilingual and accessible science."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Terminology-aware machine translation for accessible science</p>
      <h1>Science should travel across languages.</h1>
      <p class="hero-lede">
        TaMTAS is building translation technology that protects scientific terminology,
        preserves meaning across complete documents and makes complex knowledge clearer
        for different audiences.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/research">Explore the research <span>→</span></a>
        <a class="text-link" href="/project">Understand the project <span>↗</span></a>
      </div>
    </div>
    <PrismHero />
  </section>

  <div class="page-shell stats-shell" data-reveal>
    <ProjectStats />
  </div>

  <section class="section problem-section page-shell">
    <div class="section-heading">
      <p class="eyebrow">The challenge</p>
      <h2>Translation is not enough when every term carries scientific meaning.</h2>
    </div>
    <div class="problem-layout">
      <p class="section-lede">
        Scientific texts depend on specialised terminology, document-wide coherence and
        reasoning that generic translation systems often handle inconsistently.
      </p>
      <div class="problem-points">
        <article data-reveal>
          <span>01</span>
          <h3>Terminology can drift</h3>
          <p>A single concept may be translated differently across an abstract, method and conclusion.</p>
        </article>
        <article data-reveal>
          <span>02</span>
          <h3>Errors can be hard to detect</h3>
          <p>Fluent output may still contain a wrong disease, gene, treatment or methodological term.</p>
        </article>
        <article data-reveal>
          <span>03</span>
          <h3>Correct text can remain inaccessible</h3>
          <p>Readers also need explanations, summaries and language adapted to their level of expertise.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section pipeline-band">
    <div class="page-shell">
      <div class="section-heading section-heading-light">
        <p class="eyebrow">The TaMTAS pipeline</p>
        <h2>Accuracy first. Accessibility throughout.</h2>
        <p>
          Five connected research stages turn multilingual resources into evaluated,
          audience-aware scientific communication.
        </p>
      </div>
      <ResearchPipeline />
    </div>
  </section>

  <section class="section language-section page-shell">
    <div class="section-heading">
      <p class="eyebrow">Language diversity</p>
      <h2>Five languages, including three with fewer scientific resources.</h2>
      <p>
        The project combines well-resourced and lower-resourced contexts to create methods
        that can support a more equitable multilingual research ecosystem.
      </p>
    </div>
    <LanguageField />
  </section>

  <section class="section consortium-section">
    <div class="page-shell">
      <div class="section-heading">
        <p class="eyebrow">The consortium</p>
        <h2>One system, five complementary areas of expertise.</h2>
        <p>
          TaMTAS brings together terminology, multilingual AI, translation quality,
          human-centred evaluation and accessible language.
        </p>
      </div>
      <PartnerGrid />
      <a class="text-link section-link" href="/consortium">Meet the consortium and stakeholders <span>→</span></a>
    </div>
  </section>

  <section class="section foundation-section page-shell">
    <div class="foundation-intro">
      <p class="eyebrow">Open foundations</p>
      <h2>Building on tools that already serve language technology research.</h2>
      <p>
        TaMTAS will extend and connect established open-source work, then publish new
        datasets, models, applications and documentation through open repositories.
      </p>
      <a class="button button-primary" href="/resources">Browse all resources <span>→</span></a>
    </div>
    <div class="tool-list">
      {
        tools.map((tool) => (
          <a href={tool.href} data-reveal>
            <span>{tool.kind}</span>
            <h3>{tool.name}</h3>
            <p>{tool.description}</p>
            <b aria-hidden="true">↗</b>
          </a>
        ))
      }
    </div>
  </section>

  <section class="closing-section">
    <img src="/brand/tamtas-logo-mark.svg" alt="" width="640" height="640" aria-hidden="true" />
    <div>
      <p class="eyebrow">Follow the project</p>
      <h2>Research in progress. Outputs published openly.</h2>
      <p>News, publications, datasets and demonstrators will be added as the project advances.</p>
      <div class="hero-actions">
        <a class="button button-light" href="/outputs">View outputs <span>→</span></a>
        <a class="text-link text-link-light" href="/news">Read project news <span>↗</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
